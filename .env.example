# Copy this file to `.env` and fill in real values.
# NEVER commit your real `.env`, and never use `root` without a password.

# ── Database ──────────────────────────────────────────────────────────
# Use a DEDICATED MySQL user that only has privileges on THIS database,
# with a strong password. Do not point the app at `root`.
#   Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# If the password contains special characters (@ : / # ? etc.), URL-encode them.
DATABASE_URL="mysql://resort_app:CHANGE_ME_STRONG_PASSWORD@localhost:3306/resort_mdnk1"

# ── NextAuth ──────────────────────────────────────────────────────────
# Public base URL the app is served from.
NEXTAUTH_URL=http://localhost:3000

# Session-signing secret (>= 32 random bytes). Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_32_BYTES
